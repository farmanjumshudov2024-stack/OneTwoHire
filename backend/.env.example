# Put your real OpenAI key here, then restart backend
OPENAI_API_KEY=sk-your-key-here
PORT=4000
OPENAI_MODEL=gpt-4.1-mini
OPENAI_VISION_MODEL=gpt-4.1-mini

# Required for Direct Auto Apply email sending with CV attachment
# Use your email provider SMTP/app password. Applicant will be CC'd automatically.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=OneTwoHire <your-email@gmail.com>
