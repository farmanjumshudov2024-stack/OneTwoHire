# Paste your real OpenAI key below and restart start-backend.bat
# Example: OPENAI_API_KEY=sk-proj-...
OPENAI_API_KEY=
PORT=4000
OPENAI_MODEL=gpt-4.1-mini
OPENAI_VISION_MODEL=gpt-4.1-mini

# Direct Auto Apply SMTP settings
# Fill these to send CV directly to employer and CC registered user email.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
